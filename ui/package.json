{
  "name": "applykit-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 1420",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:a11y": "vitest run src/test/a11y.test.tsx",
    "test:e2e:a11y": "playwright test --config=playwright.config.ts --project=chromium",
    "test:responsive": "vitest run src/test/responsive.test.tsx",
    "test:coverage": "vitest run --coverage --coverage.provider=v8 --coverage.reportsDirectory=../coverage/ui --coverage.reporter=json-summary --coverage.reporter=lcov --coverage.reporter=text-summary",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tauri-apps/api": "^2.11.0",
    "cmdk": "^1.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^27.2.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.1",
    "vite": "7.3.2",
    "vitest": "^4.1.5"
  }
}
